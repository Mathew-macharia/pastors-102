# Copy to `.env` and fill in.

HELIUS_API_KEY=
TRITON_RPC_URL=https://your-app.mainnet.rpcpool.com/your-secret-token

# Pump.fun fee_recipient for the current epoch. To find it:
#   1. open https://solscan.io/, search any recent Pump.fun token
#   2. open one of the BUY transactions, look at the "Account Inputs"
#   3. the second account in the list is the fee_recipient -- copy it here
# This value occasionally rotates; verify it's current before launching.
PUMP_FEE_RECIPIENT=

# Optional: bind address for the UI. Default 127.0.0.1:7777.
# UI_BIND=127.0.0.1:7777
