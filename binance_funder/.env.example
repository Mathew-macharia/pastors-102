# Option B: split 40 wallets across OKX (24) + Bybit (16) on-chain withdrawals.
# Copy to .env and fill. Never commit .env.

# --- OKX (Funding account) ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# --- Bybit (Funding wallet — transfer SOL here from UTA if needed) ---
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Row split after sorting wallets.csv by `index` ascending:
# first OKX_WALLET_COUNT rows -> OKX, remainder -> Bybit (must sum to wallet count).
OKX_WALLET_COUNT=24
BYBIT_WALLET_COUNT=16

# Optional: override auto-detected OKX chain / network fee (from GET /api/v5/asset/currencies?ccy=SOL).
# OKX_SOL_CHAIN=SOL-Solana
# OKX_SOL_FEE=0.008
# OKX_MIN_WD=0.01

# Optional: Bybit chain id for SOL (default SOL). Must match address book network.
# BYBIT_SOL_CHAIN=SOL

# Optional: use EU OKX domain or testnet (advanced).
# OKX_API_BASE=https://www.okx.com
# BYBIT_API_BASE=https://api.bybit.com
